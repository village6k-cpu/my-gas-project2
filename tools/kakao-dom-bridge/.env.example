PORT=8787
DEBOUNCE_MS=90000
MAX_WAIT_MS=300000
STARTUP_MUTATION_IGNORE_MS=4000
QUEUE_DIR=./queue

# Optional: Supabase 처리판에 pending_ai_review / ready_for_ai_worker 이벤트를 저장할 때만 설정
# 먼저 Supabase SQL Editor에서 tools/kakao-dom-bridge/supabase-schema.sql 을 실행하세요.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_TABLE=ai_processing_events
SUPABASE_FOLLOW_UP_TABLE=ai_follow_up_items

# Optional: debounce 완료 후 AI 브라우저 직원 실행 명령
# Payload is passed as stdin JSON.
# Leave commented until the real AI worker command exists.
# If enabled, quote the value because it contains spaces.
# VILLAGE_AI_WORKER_CMD="node ../your-ai-browser-worker/index.mjs"

# Optional: live Hermes worker safety timeout. Keep short enough that one Kakao message cannot hang for 10+ minutes.
HERMES_WORKER_TIMEOUT_MS=180000

# Optional: durable recovery. The bridge periodically replays ready/error jobs that survived a restart or timeout.
SUPABASE_RECOVERY_ENABLED=true
SUPABASE_RECOVERY_INTERVAL_MS=300000
SUPABASE_RECOVERY_BATCH_SIZE=2
SUPABASE_RECOVERY_LOOKBACK_HOURS=36
SUPABASE_RECOVERY_ERROR_RETRY_MS=900000
SUPABASE_RECOVERY_MAX_ATTEMPTS=2

# Optional: route follow-up items to Slack as actionable Block Kit work cards.
# Requires Slack bot token scopes: chat:write, channels:read, groups:read.
SLACK_FOLLOW_UP_ENABLED=false
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_AGENT_MENTION=헤이빌리
SLACK_CHANNEL_SCHEDULE_AGENT=스케쥴-agent
SLACK_CHANNEL_DOCUMENT_AGENT=서류발송-agent
SLACK_CHANNEL_SETTLEMENT_AGENT=정산-agent
SLACK_CHANNEL_OTHER_AGENT=기타문의
SLACK_DASHBOARD_URL=https://village-follow-up-dashboard.vercel.app

# Optional: local bridge consumes Slack "전송" button requests stored in Supabase.
SLACK_ACTION_POLL_ENABLED=true
SLACK_ACTION_POLL_INTERVAL_MS=10000

# Optional: close stale individual Kakao conversation tabs when the worker is idle.
KAKAO_TAB_CLEANUP_ENABLED=true
KAKAO_TAB_CLEANUP_INTERVAL_MS=120000

# Optional: keep automation quality first while avoiding the worst human conflicts.
# devtools_first uses the isolated automation Chrome DevTools first, then keeps
# CUA as the high-fidelity fallback after only a short human-idle buffer.
# devtools_only disables CUA and is not recommended for normal operation.
# Set to cua_first only for emergency debugging.
KAKAO_WORKER_CONTROL_MODE=devtools_first
KAKAO_CUA_MIN_IDLE_SECONDS=15

# Optional: village-ai read-only RAG reference search for the AI worker.
# Do NOT give Hermes Supabase/RPC/Cohere keys. Use village-ai /api/ask as a reference-answer tool only.
# RAG must be used only after Kakao conversation is opened, and only as reference memory.
# It must not replace Kakao screen evidence or Sheets/GAS duplicate checks.
# VILLAGE_AI_URL=http://localhost:3000
# VILLAGE_AI_KAKAO_SKILL_SECRET=replace-me
# VILLAGE_AI_RAG_TIMEOUT_MS=30000
